    {
      "name": "Prueba API crear material",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 (Creado exitosamente)\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Es un JSON válido\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "pm.test(\"El objeto devuelto coincide con el enviado\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    pm.expect(jsonData.nombre).to.eql(\"cemento cruz azul\");\r",
              "    pm.expect(jsonData.costo).to.eql(215.50);\r",
              "    pm.collectionVariables.set(\"material_id\", jsonData.id);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
