    {
      "name": "Prueba API actualizar material",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 (Actualizado exitosamente)\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Es un JSON válido\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "pm.test(\"Los datos reflejan la actualización\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    pm.expect(jsonData.costo).to.eql(250.00);\r",
              "    \r",
              "    var idEsperado = pm.collectionVariables.get(\"material_id\");\r",
              "    \r",
              "    pm.expect(jsonData.id).to.eql(idEsperado); \r",
              "});"
            ],
