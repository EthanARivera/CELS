    {
      "name": "Pruebas API matierales",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Es un JSON válido\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "pm.test(\"La búsqueda retornó resultados\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an('array');\r",
              "});\r",
              "\r",
              "const schema = {\r",
              "  \"type\": \"array\",\r",
              "  \"items\": {\r",
              "    \"type\": \"object\",\r",
              "    \"properties\": {\r",
              "      \"id\": { \"type\": \"number\" },\r",
              "      \"nombre\": { \"type\": \"string\" },\r",
              "      \"costo\": { \"type\": \"number\" },\r",
              "      \"tipo_material\": { \"type\": \"string\" }\r",
              "    },\r",
              "    \"required\": [\"id\", \"nombre\"]\r",
              "  }\r",
              "};\r",
              "\r",
              "pm.test(\"La estructura de los materiales es correcta\", function () {\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/vista_war_exploded/buscarMateriales?texto=cemento",
          "protocol": "http",
          "host": [
